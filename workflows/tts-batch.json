    {
      "parameters": {
        "jsCode": "\n// Validate input\nconst body = $input.item.json.body;\nconst project_id = body.project_id;\nconst scenes = body.scenes || [];\nconst language = body.language || \"en-US\";\n\nif (!project_id || !Array.isArray(scenes) || scenes.length === 0) {\n  throw new Error(\"Missing required fields: project_id and scenes array\");\n}\n\n// Return all scenes for batch processing\nreturn scenes.map((scene, index) => ({\n  json: {\n    project_id,\n    scene_id: scene.scene_id || `scene_${index + 1}`,\n    text: scene.text || scene.screenplay_text || \"\",\n    voice: scene.voice || body.default_voice || \"Algieba\",\n    language: scene.language || language,\n    total_scenes: scenes.length,\n    scene_index: index + 1\n  }\n}));\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        192
      ],
      "id": "validate-preprocess",
      "name": "Validate & Preprocess"
    },
    {
      "parameters": {
        "jsCode": "\nconst voice = $json.voice || \"Algieba\";\nconst language = $json.language || \"en-US\";\n\nreturn [{\n  json: {\n    ...$json,\n    voice_full: `en-US-Chirp3-HD-${voice}`\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        208
      ],
      "id": "build-voice",
      "name": "Build Voice Name"
    },
    {
