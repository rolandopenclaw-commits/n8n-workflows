        "url": "http://ncat:8080/v1/image/convert/video",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"image_url\": \"{{ $('Validate Input').item.json.image_url }}\",\n  \"length\": {{ $('Validate Input').item.json.duration }},\n  \"frame_rate\": 25,\n  \"zoom_speed\": {{ $('Validate Input').item.json.intensity > 0.15 ? 1.35 : 1.25 }},\n  \"id\": \"{{ $('Validate Input').item.json.shot_id }}\"\n}",
        "options": {
