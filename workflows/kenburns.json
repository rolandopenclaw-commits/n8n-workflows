      "parameters": {
        "jsCode": "const webhookData = $('Webhook').item.json;\nconst input = webhookData.body || webhookData;\nconst errors = [];\n\nif (!input.shot_id) errors.push(\"Missing: shot_id\");\nif (!input.scene_id) errors.push(\"Missing: scene_id\");\nif (!input.image_url) errors.push(\"Missing: image_url\");\nif (!input.duration) errors.push(\"Missing: duration\");\n\nif (errors.length > 0) {\n  throw new Error(\"Validation failed: \" + errors.join(\", \"));\n}\n\nreturn {\n  shot_id: input.shot_id,\n  scene_id: input.scene_id,\n  image_url: input.image_url,\n  duration: parseFloat(input.duration) || 4.0,\n  motion_type: input.motion_type || input.motion || \"zoom_in\",\n  intensity: input.options?.intensity || 0.15,\n  easing: input.options?.easing || \"ease-in-out\"\n};"
      }
    },
