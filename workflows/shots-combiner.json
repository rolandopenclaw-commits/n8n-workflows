      "id": "compose-001",
      "name": "ncat: Add Audio",
      "parameters": {
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "jsonBody": "={\n  \"inputs\": [\n    {\"file_url\": \"{{ $json.response }}\"},\n    {\"file_url\": \"{{ $('Validate Input').item.json.audio_url }}\"}\n  ],\n  \"outputs\": [\n    {\n      \"options\": [\n        {\"option\": \"-map\", \"argument\": \"0:v:0\"},\n        {\"option\": \"-map\", \"argument\": \"1:a:0\"},\n        {\"option\": \"-c:v\", \"argument\": \"copy\"},\n        {\"option\": \"-c:a\", \"argument\": \"aac\"},\n        {\"option\": \"-shortest\"}\n      ]\n    }\n  ]\n}",
        "method": "POST",
        "options": {
          "timeout": 300000
        },
        "sendBody": true,
        "specifyBody": "json",
        "url": "http://ncat:8080/v1/ffmpeg/compose"
      },
