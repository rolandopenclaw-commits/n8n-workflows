    },
    {
      "id": "build-response-001",
      "name": "Build Response",
      "parameters": {
        "jsCode": "const validateInput = $('Validate Input').item.json;\nlet videoUrl = '';\n\nif ($json.response && Array.isArray($json.response) && $json.response[0] && $json.response[0].file_url) {\n  videoUrl = $json.response[0].file_url;\n} else if ($json.response && typeof $json.response === 'string') {\n  videoUrl = $json.response;\n} else if ($json.response && $json.response.file_url) {\n  videoUrl = $json.response.file_url;\n}\n\nreturn {\n  success: true,\n  scene_id: validateInput.scene_id,\n  video_url: videoUrl,\n  audio_url: validateInput.audio_url || null\n};"
      },
