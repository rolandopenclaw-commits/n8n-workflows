    {
      "id": "validate-input-002",
      "name": "Validate Input",
      "parameters": {
        "jsCode": "const webhookData = $('Webhook').item.json;\nconst input = webhookData.body || webhookData;\nconst errors = [];\n\nif (!input.scene_id) errors.push(\"Missing: scene_id\");\nif (!input.video_urls || !Array.isArray(input.video_urls) || input.video_urls.length === 0) {\n  errors.push(\"Missing or empty: video_urls array\");\n}\nconst hasAudio = !!input.audio_url;\n\nif (errors.length > 0) {\n  throw new Error(\"Validation failed: \" + errors.join(\", \"));\n}\n\nreturn {\n  scene_id: input.scene_id,\n  audio_url: input.audio_url || null,\n  has_audio: hasAudio,\n  output: JSON.stringify({\n    video_urls: input.video_urls,\n    id: input.scene_id\n  })\n};"
      },
      "position": [
        -240,
        -112
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
