      "name": "Format Shot Output"
    },
    {
      "parameters": {
        "jsCode": "// Aggregate all shots into response\nconst allItems = $input.all();\nconst sceneId = allItems[0].json.scene_id || $('Validate Input').first().json.scene_id;\n\nconst shots = allItems.map(item => ({\n  shot_num: item.json.shot_num,\n  shot_narration: item.json.shot_narration,\n  image_url: item.json.image_url\n})).sort((a, b) => a.shot_num - b.shot_num);\n\nreturn {\n  status: \"success\",\n  scene_id: sceneId,\n  shot_count: shots.length,\n  shots: shots\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -112,
        -336
      ],
      "id": "aggregate-output",
      "name": "Aggregate Response"
    },
