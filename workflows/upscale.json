      "id": "7892315f-4a3b-4c5f-8f83-0421bf557218",
      "name": "Respond to Webhook"
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "upscale",
        "responseMode": "responseNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        -1216,
        -64
      ],
      "id": "ac6879a2-14b5-4741-9a69-105bb5303914",
      "name": "Webhook",
      "webhookId": "5ae39768-203d-4d48-8281-6360d18d90e7"
    },
    {
      "parameters": {
        "jsCode": "  // Validate and prepare input - explicitly reference Webhook node                                 \n  const webhookData = $('Webhook').item.json;                                                       \n  const input = webhookData.body || webhookData;                                                    \n  const errors = [];                                                                                \n                                                                                                    \n  if (!input.scene_id) errors.push(\"Missing: scene_id\");                                            \n  if (!input.storyboard_url) errors.push(\"Missing: storyboard_url\");                                \n  if (!input.shots || !Array.isArray(input.shots)) errors.push(\"Missing: shots array\");             \n                                                                                                    \n  if (errors.length > 0) {                                                                          \n    throw new Error(\"Validation failed: \" + errors.join(\", \"));                                     \n  }                                                                                                 \n                                     \n  // Return scene data + expanded shots array                                                       \n  return input.shots.map((shot, index) => ({\n    scene_id: input.scene_id,                                                                       \n    storyboard_url: input.storyboard_url,                                                           \n    shot_num: shot.shot_num || index + 1,                                                           \n    shot_narration: shot.shot_narration,                                                            \n    total_shots: input.shots.length,                                                                \n    style: input.style || \"cinematic\",                                                              \n    aspect_ratio: input.aspect_ratio || \"16:9\"                                                      \n  }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -592,
