          "assignments": [
            {
              "id": "storyboard-prompt",
              "name": "storyboard_prompt",
              "value": "=Create a SINGLE composite storyboard image with exactly {{ $json.shot_count }} panels arranged in a horizontal strip layout.\n\nScene narration to visualize across panels:\n\"{{ $json.narration_text }}\"\n\nRequirements:\n- ONE image containing {{ $json.shot_count }} distinct panels side by side\n- Each panel shows a sequential moment from the narration\n- Style: {{ $json.style }}\n- Overall aspect ratio: {{ $json.aspect_ratio }}\n- {{ $json.imagery_tone }}\n- Clear visual separation between panels\n- Cinematic composition in each panel\n- Consistent visual style across all panels\n\nThe image should be a professional storyboard suitable for video production planning.",
              "type": "string"
            }
          ]
        },
