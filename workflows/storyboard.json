      "parameters": {
        "jsCode": "// Validate input\nconst input = $input.item.json.body || $input.item.json;\nconst errors = [];\n\nif (!input.scene_id) errors.push(\"Missing: scene_id\");\nif (!input.narration_text) errors.push(\"Missing: narration_text\");\nif (!input.shot_count) errors.push(\"Missing: shot_count\");\n\nif (errors.length > 0) {\n  throw new Error(\"Validation failed: \" + errors.join(\", \"));\n}\n\nreturn {\n  scene_id: input.scene_id,\n  narration_text: input.narration_text,\n  shot_count: parseInt(input.shot_count),\n  style: input.style || \"cinematic\",\n  aspect_ratio: input.aspect_ratio || \"16:9\",\n  imagery_tone: input.imagery_tone || \"high quality, professional\"\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -384,
        -176
